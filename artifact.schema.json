{
  "policy_pack_id": "publication-policy-v1",
  "version": "1.0.0",
  "domain": "weather",
  "rules": [
    {
      "rule_id": "DO_NOT_PUBLISH_WITHOUT_EVIDENCE",
      "deontic": "MUST_NOT",
      "condition": "evidence_complete == false",
      "effect_if_failed": "ABSTAIN",
      "reason_code": "insufficient_evidence_for_publication",
      "artifact_required": true
    },
    {
      "rule_id": "PUBLICATION_REQUIRES_VERDICT",
      "deontic": "MUST",
      "condition": "gatekeeper_verdict_exists == true",
      "effect_if_failed": "BLOCK",
      "reason_code": "missing_gatekeeper_verdict",
      "artifact_required": true
    }
  ]
}
